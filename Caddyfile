# Edge Caddy is the ONLY internet-facing proxy in this topology.
# It routes hostnames to loopback-bound upstreams on the **host**.
# Requires `network_mode: host` in docker-compose so `127.0.0.1` here is the host, not the container.

hms.162.62.230.162.nip.io {
  reverse_proxy 127.0.0.1:18080
}

ceai.162.62.230.162.nip.io {
  reverse_proxy 127.0.0.1:28080
}

ceai.operator.162.62.230.162.nip.io {
  reverse_proxy 127.0.0.1:28081
}
